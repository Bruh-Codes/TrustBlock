

# NEXT_PUBLIC_STELLAR_NETWORK: White Belt network target for the frontend shell.
# Use TESTNET while preparing your first submission.
NEXT_PUBLIC_STELLAR_NETWORK="TESTNET"

# NEXT_PUBLIC_SOROBAN_CONTRACT_ID: Fill this once the Soroban escrow contract is deployed.
NEXT_PUBLIC_SOROBAN_CONTRACT_ID=""

# NEXT_PUBLIC_SUPABASE_URL: Public Supabase project URL used for PostgREST queries.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY: Public publishable key used by the PostgREST client.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"

# NEXT_PUBLIC_SUPABASE_ATTACHMENTS_BUCKET: Public bucket name used for milestone attachments.
NEXT_PUBLIC_SUPABASE_ATTACHMENTS_BUCKET="trustblock-attachments"

# DATABASE_URL: Private server-side Postgres connection string for Drizzle.
# Use the Supabase Postgres connection string from the project Connect panel.
# Do not prefix this with NEXT_PUBLIC.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"
